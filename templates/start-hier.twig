{% extends "_layout" %}

{% set topics = craft.categories()
  .group('topics')
  .all() %}

{% set topicSlug = craft.app.request.getSegment(2) %}
{% set selectedTopic = topicSlug
  ? craft.categories().group('topics').slug(topicSlug).one()
  : craft.categories().group('topics').one()
%}

{% set searchQuery = craft.app.request.getQueryParam('q') ?? '' %}
{% set sort = craft.app.request.getQueryParam('sort') ?? 'recent' %}

{% set articlesQuery = craft.entries()
  .section('articles')
  .relatedTo({
    targetElement: selectedTopic,
    field: 'articletopic'
  })
%}

{% if searchQuery %}
	{% set articlesQuery = articlesQuery.search(searchQuery) %}
{% endif %}

{% if sort == 'oldest' %}
	{% set articlesQuery = articlesQuery.orderBy('postDate asc') %}
{% elseif sort == 'popular' %}
	{% do craft.viewCount.sort(articlesQuery) %}
{% else %}
	{% set articlesQuery = articlesQuery.orderBy('postDate desc') %}
{% endif %}

{% set articles = selectedTopic ? articlesQuery.all() : [] %}

{% block title %}
	{% if selectedTopic %}
		{{ selectedTopic.title }}
		— Start hier — Watnu
	{% else %}
		Start hier — Watnu
	{% endif %}
{% endblock %}

{% block styles %}
	<link rel="stylesheet" href="{{ alias('@web') }}/css/pages/start-hier.css">
{% endblock %}

{% block header %}
	{% include "_partials/header.twig" with {
    current: 'start-hier',
    variant: 'topbar'
  } %}
{% endblock %}

{% block content %}
	<section class="topic-menu" aria-label="Thema's">
		<div class="container">
			<div class="topic-menu-inner" role="tablist" aria-label="Thema tabs" id="topicMenu">
				{% for topic in topics %}
					{% set isActive = selectedTopic and selectedTopic.id == topic.id %}
					{% set color = topic.topiccolor ?: '#4C40FD' %}

					<a class="topic-pill {{ isActive ? 'is-active' }}" role="tab" aria-selected="{{ isActive ? 'true' : 'false' }}" href="{{ url('start-hier/' ~ topic.slug, { q: searchQuery, sort: sort }) }}" data-topic-pill data-topic-slug="{{ topic.slug }}" data-topic-color="{{ color }}">
						<span class="topic-dot" style="background: {{ color }};" aria-hidden="true"></span>
						<span class="topic-label">{{ topic.title }}</span>
					</a>
				{% endfor %}

				<span class="topic-underline" id="topicUnderline" aria-hidden="true"></span>
			</div>
		</div>
	</section>

	{% if selectedTopic %}
		{% set topicIcon = selectedTopic.topicicon.one() %}
		{% set topicColor = selectedTopic.topiccolor ?: '#4C40FD' %}

		<section class="page-head">
			<div class="container page-head-inner">
				<div class="topic-icon" aria-hidden="true" style="background: {{ topicColor }};">
					{% if topicIcon %}
						<img src="{{ topicIcon.url }}" alt="" loading="lazy" width="22" height="22">
					{% endif %}
				</div>

				<div>
					<h1 class="page-title">{{ selectedTopic.title }}</h1>
					<p class="page-subtitle">
						{{ selectedTopic.topicsubtitle }}
					</p>
				</div>
			</div>
		</section>

		<section class="search-wrap" aria-label="Zoeken en sorteren">
			<div class="container">
				<form method="get" action="{{ url('start-hier/' ~ selectedTopic.slug) }}" class="search-controls">
					<div class="search-control">
						<label class="sr-only" for="search">Zoek</label>
						<input id="search" name="q" class="search" type="search" placeholder="Zoek in dit thema…" value="{{ searchQuery }}">
					</div>

					<div class="sort-control">
						<label class="sr-only" for="sort">Sorteer op</label>
						<select id="sort" name="sort" class="sort-select">
							<option value="recent" {{ sort == 'recent' ? 'selected' }}>Meest recent</option>
							<option value="oldest" {{ sort == 'oldest' ? 'selected' }}>Oudst eerst</option>
							<option value="popular" {{ sort == 'popular' ? 'selected' }}>Populariteit</option>
						</select>
					</div>
				</form>
			</div>
		</section>

		<section class="qa-grid" aria-label="Vragen">
			<div class="container">
				<div class="grid" role="list">
					{% for article in articles %}
						{% set featuredImage = article.articlefeaturedimage.one() %}

						<a class="qa-card" href="{{ article.url }}" role="listitem" aria-label="{{ article.title }}">
							<div class="qa-thumb">
								{% if featuredImage %}
									<img src="{{ featuredImage.url }}" alt="{{ article.title }}" loading="lazy" style="width: 100%; height: 100%; object-fit: cover;">
								{% endif %}

								{% if article.articleTags|length %}
									<div class="qa-tags">
										{% for tag in article.articleTags.limit(2).all() %}
											<span class="tag" style="background: {{ topicColor }};">
												{{ tag.title }}
											</span>
										{% endfor %}
									</div>
								{% endif %}
							</div>

							<div class="qa-footer">
								<div class="qa-title">{{ article.title }}</div>

								{% if article.articleexcerpt %}
									<p class="qa-excerpt">{{ article.articleexcerpt }}</p>
								{% endif %}

								{% if article.articlereadingtime %}
									<p class="qa-meta">{{ article.articlereadingtime }}
										min lezen</p>
								{% endif %}
							</div>
						</a>
					{% else %}
						<p class="count">Er zijn nog geen artikelen binnen ‘{{ selectedTopic.title }}’.</p>
					{% endfor %}
				</div>

				{% if articles|length %}
					<p class="count">
						{{ articles|length }}
						{{ articles|length == 1 ? 'artikel' : 'artikelen' }}
						in ‘{{ selectedTopic.title }}’
					</p>
				{% endif %}
			</div>
		</section>
	{% else %}
		<section class="qa-grid" aria-label="Vragen">
			<div class="container">
				<p class="count">Geen geldig thema gevonden.</p>
			</div>
		</section>
	{% endif %}

	<section class="cta-band" aria-label="Geen antwoord">
		<div class="container cta-inner">
			<h2 class="cta-title">Vind je geen antwoord op jouw vragen?</h2>
			<p class="cta-text">
				Laat het ons weten. Jij bent waarschijnlijk niet de enige met de vraag.<br>
				Zo zorgen wij ervoor dat we het antwoord zoeken en anderen meteen ook zijn geholpen.
			</p>
			<a class="cta-btn" href="{{ url('contact') }}">Stuur ons jouw vraag!</a>
		</div>
	</section>
{% endblock %}

{% block footer %}
	{% include "_partials/footer.twig" %}
{% endblock %}

{% block scripts %}
	<script src="{{ alias('@web') }}/js/animations/topic-animation.js"></script>
  <script src="{{ alias('@web') }}/js/animations/article-load-animation.js"></script>
	<script>
		document.addEventListener('DOMContentLoaded', () => {
const sortSelect = document.getElementById('sort');
if (! sortSelect)
return;



sortSelect.addEventListener('change', () => {
sortSelect.form.submit();
});
});
	</script>
{% endblock %}
