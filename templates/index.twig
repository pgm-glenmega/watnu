{% extends "_layout" %}

{% block title %}Watnu
{% endblock %}

{% block styles %}
	<link rel="stylesheet" href="{{ alias('@web') }}/css/pages/index.css">
{% endblock %}

{% block header %}
	{% include "_partials/header.twig" with {
    current: 'home',
    variant: 'home'
  } %}
{% endblock %}

{% block content %}
	{% set topics = craft.categories()
    .group('topics')
    .all() %}

	<section class="hero" aria-label="Intro">
		<div class="hero-bg" aria-hidden="true"></div>
		<div class="hero-overlay" aria-hidden="true"></div>

		<div class="hero-content">
			<div class="hero-logo">
				<span class="hero-logo-mark">W</span>
				<span class="hero-logo-text">atnu</span>
			</div>

			<h1 class="hero-title">Jouw startpunt voor het echte leven.</h1>

			<p class="hero-subtitle">
				Van geld tot werk, van huisvesting tot administratie.<br>
				De dingen die jij wou dat iemand jou had uitgelegd.
			</p>

			<a class="btn btn-primary" href="{{ url('start-hier') }}">Ontdek de thema's</a>
		</div>
	</section>

	<section class="section section-intro">
		<div class="container">
			<h2 class="section-title">
				Watnu is er voor de momenten wanneer jij denkt:
			</h2>
			<p class="section-quote">“Oké... en wat nu?”</p>

			<div class="three-col">
				<div class="blurb">
					<h3 class="blurb-title">
						Het ‘echte’ leven<br/>komt zonder handleiding.
					</h3>
					<p class="blurb-text">
						Op school leerden we algebra, maar niet hoe je belastingen doet
																								of een huurcontract leest.
					</p>
				</div>

				<div class="blurb">
					<h3 class="blurb-title">
						Geen oordeel,<br/>gewoon duidelijkheid.
					</h3>
					<p class="blurb-text">
						We splitsen ingewikkelde onderwerpen op in eenvoudige, concrete
																								stappen die je daadwerkelijk kunt volgen.
					</p>
				</div>

				<div class="blurb">
					<h3 class="blurb-title">Watnu is<br/>jouw startpunt.</h3>
					<p class="blurb-text">
						Wij helpen je de eerste stap te zetten. Dat is vaak het
																								moeilijkste deel.
					</p>
				</div>
			</div>
		</div>
	</section>

	<section class="section section-topics">
		<div class="container">
			<h2 class="topics-title">Begin bij wat voor jou telt</h2>
			<p class="topics-subtitle">
				Kies een thema, krijg praktische uitleg en zet je eerste stap.<br/>
				Geen druk. Geen overload. Gewoon duidelijkheid
			</p>

			<div class="cards" role="list">
				{% for topic in topics %}
					{% set icon = topic.topicicon.one() %}
					{% set color = topic.topiccolor ?: '#4C40FD' %}

					<article class="card" role="listitem">
						<div class="card-icon" aria-hidden="true" style="background: {{ color }};">
							{% if icon %}
								<img src="{{ icon.url }}" alt="" loading="lazy" width="20" height="20">
							{% endif %}
						</div>

						<h3 class="card-title">{{ topic.title }}</h3>

						{% if topic.topicsubtitle %}
							<p class="card-text">{{ topic.topicsubtitle }}</p>
						{% endif %}

						<a class="card-link" href="{{ url('start-hier/' ~ topic.slug) }}">
							Leer meer ->
						</a>
					</article>
				{% endfor %}
			</div>

			<div class="cta-row">
				<a class="btn btn-outline" href="{{ url('contact') }}">Vind een antwoord op jouw vraag!</a>
			</div>
		</div>
	</section>

{% endblock %}

{% block footer %}
	{% include "_partials/footer.twig" %}
{% endblock %}
