{% extends "_layout" %}

{% block title %}Watnu
{% endblock %}

{% block styles %}
	<link rel="stylesheet" href="{{ alias('@web') }}/css/index.css">
{% endblock %}

{% block header %}
	{% include "_partials/header.twig" with {
    current: 'home',
    variant: 'home'
  } %}
{% endblock %}

{% block content %}
	<section class="hero" aria-label="Intro">
		<div class="hero-bg" aria-hidden="true"></div>
		<div class="hero-overlay" aria-hidden="true"></div>

		<div class="hero-content">
			<div class="hero-logo">
				<span class="hero-logo-mark">W</span>
				<span class="hero-logo-text">atnu</span>
			</div>

			<h1 class="hero-title">Jouw startpunt voor het echte leven.</h1>

			<p class="hero-subtitle">
				Van geld tot werk, van huisvesting tot administratie.<br>
				De dingen die jij wou dat iemand jou had uitgelegd.
			</p>

			<a class="btn btn-primary" href="{{ url('start-hier') }}">Ontdek de thema's</a>
		</div>
	</section>

	<section class="section section-intro">
		<div class="container">
			<h2 class="section-title">
				Watnu is er voor de momenten wanneer jij denkt:
			</h2>
			<p class="section-quote">“Oké... en wat nu?”</p>

			<div class="three-col">
				<div class="blurb">
					<h3 class="blurb-title">
						Het ‘echte’ leven<br/>komt zonder handleiding.
					</h3>
					<p class="blurb-text">
						Op school leerden we algebra, maar niet hoe je belastingen doet
						                of een huurcontract leest.
					</p>
				</div>

				<div class="blurb">
					<h3 class="blurb-title">
						Geen oordeel,<br/>gewoon duidelijkheid.
					</h3>
					<p class="blurb-text">
						We splitsen ingewikkelde onderwerpen op in eenvoudige, concrete
						                stappen die je daadwerkelijk kunt volgen.
					</p>
				</div>

				<div class="blurb">
					<h3 class="blurb-title">Watnu is<br/>jouw startpunt.</h3>
					<p class="blurb-text">
						Wij helpen je de eerste stap te zetten. Dat is vaak het
						                moeilijkste deel.
					</p>
				</div>
			</div>
		</div>
	</section>

	<section class="section section-topics">
		<div class="container">
			<h2 class="topics-title">Begin bij wat voor jou telt</h2>
			<p class="topics-subtitle">
				Kies een thema, krijg praktische uitleg en zet je eerste stap.<br/>
				Geen druk. Geen overload. Gewoon duidelijkheid
			</p>

			<div class="cards" role="list">
				<article class="card" role="listitem">
					<div class="card-icon" data-icon="money" aria-hidden="true"></div>
					<h3 class="card-title">Geld</h3>
					<p class="card-text">
						Budgetteren, sparen en grip krijgen op je financiën zonder
						                stress.
					</p>
					<a class="card-link" href="#">Leer meer →</a>
				</article>

				<article class="card" role="listitem">
					<div class="card-icon" data-icon="work" aria-hidden="true"></div>
					<h3 class="card-title">Werk</h3>
					<p class="card-text">
						Een job vinden, contracten begrijpen en je rechten als werknemer
						                kennen.
					</p>
					<a class="card-link" href="#">Leer meer →</a>
				</article>

				<article class="card" role="listitem">
					<div class="card-icon" data-icon="home" aria-hidden="true"></div>
					<h3 class="card-title">Wonen</h3>
					<p class="card-text">
						Huren, waarborgen, huurdersrechten en van een plek een thuis
						                maken.
					</p>
					<a class="card-link" href="#">Leer meer →</a>
				</article>

				<article class="card" role="listitem">
					<div class="card-icon" data-icon="care" aria-hidden="true"></div>
					<h3 class="card-title">Zorg</h3>
					<p class="card-text">
						Ziekteverzekering, een dokter vinden en goed voor jezelf zorgen
						                zonder verwarring.
					</p>
					<a class="card-link" href="#">Leer meer →</a>
				</article>

				<article class="card" role="listitem">
					<div class="card-icon" data-icon="law" aria-hidden="true"></div>
					<h3 class="card-title">Recht</h3>
					<p class="card-text">
						Contracten, je rechten en basiskennis die iedereen zou moeten
						                hebben.
					</p>
					<a class="card-link" href="#">Leer meer →</a>
				</article>

				<article class="card" role="listitem">
					<div class="card-icon" data-icon="mind" aria-hidden="true"></div>
					<h3 class="card-title">Mentaal welzijn</h3>
					<p class="card-text">
						Zorg dragen voor je hoofd, omgaan met stress en weten wanneer je
						                hulp mag vragen.
					</p>
					<a class="card-link" href="#">Leer meer →</a>
				</article>

				<article class="card" role="listitem">
					<div class="card-icon" data-icon="relations" aria-hidden="true"></div>
					<h3 class="card-title">Relaties</h3>
					<p class="card-text">
						Gezonde connecties, grenzen stellen en omgaan met sociale
						                situaties.
					</p>
					<a class="card-link" href="#">Leer meer →</a>
				</article>

				<article class="card" role="listitem">
					<div class="card-icon" data-icon="mobility" aria-hidden="true"></div>
					<h3 class="card-title">Mobiliteit</h3>
					<p class="card-text">
						Je verplaatsen: autorijden, openbaar vervoer en verhuizen naar
						                nieuwe plekken.
					</p>
					<a class="card-link" href="#">Leer meer →</a>
				</article>
			</div>

			<div class="cta-row">
				<a class="btn btn-outline" href="#">Vind een antwoord op jouw vraag!</a>
			</div>
		</div>
	</section>

{% endblock %}

{% block footer %}
	{% include "_partials/footer.twig" %}
{% endblock %}
