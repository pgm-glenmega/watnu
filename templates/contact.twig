{% extends "_layout" %}

{% set submission = submission ?? null %}

{% macro errorList(errors) %}
	{% if errors %}
		{{ ul(errors, { class: 'errors' }) }}
	{% endif %}
{% endmacro %}

{% from _self import errorList %}

{% block title %}Contact — Watnu
{% endblock %}

{% block styles %}
	<link rel="stylesheet" href="{{ alias('@web') }}/css/pages/contact.css">
{% endblock %}

{% block header %}
	{% include "_partials/header.twig" with {
    current: 'contact',
    variant: 'topbar'
  } %}
{% endblock %}

{% block content %}
	<section class="contact-hero" aria-label="Contact">
		<div class="container contact-hero-inner">
			<h1 class="contact-title">Deel je vraag</h1>
			<p class="contact-subtitle">
				Is er iets waarvan jij wou dat iemand het jou had uitgelegd?<br>
				We horen het graag van je.
			</p>

			{% if craft.app.session.hasFlash('success') %}
				<p class="form-message form-message--success">
					{{ craft.app.session.getFlash('success') }}
				</p>
			{% elseif craft.app.session.hasFlash('error') %}
				<p class="form-message form-message--error">
					{{ craft.app.session.getFlash('error') }}
				</p>
			{% endif %}

			{% set sent = craft.app.request.getQueryParam('sent') %}

			{% if sent %}
				<div class="form-message form-message--success" role="status" aria-live="polite">
					Je vraag is succesvol verzonden. We hebben ze goed ontvangen.
				</div>
			{% elseif craft.app.session.hasFlash('error') %}
				<div class="form-message form-message--error" role="alert">
					{{ craft.app.session.getFlash('error') }}
				</div>
			{% endif %}

			<form class="contact-form" method="post" action="" accept-charset="UTF-8">
				{{ csrfInput() }}
				{{ actionInput('contact-form/send') }}
				{{ redirectInput('contact') }}

				<div class="form-row">
					<div class="field">
						<label class="label" for="from-name">Jouw naam</label>
						{{ input('text', 'fromName', submission.fromName ?? '', {
              id: 'from-name',
              class: 'input',
              placeholder: 'Hoe moeten we jou noemen?',
              autocomplete: 'name'
            }) }}
						{{ submission ? errorList(submission.getErrors('fromName')) }}
					</div>

					<div class="field">
						<label class="label" for="from-email">E-mailadres</label>
						{{ input('email', 'fromEmail', submission.fromEmail ?? '', {
              id: 'from-email',
              class: 'input',
              placeholder: 'Voor het geval je een antwoord terug wilt.',
              autocomplete: 'email'
            }) }}
						{{ submission ? errorList(submission.getErrors('fromEmail')) }}
					</div>
				</div>

				<div class="field field-full">
					<label class="label" for="subject">Onderwerp</label>
					{{ input('text', 'subject', submission.subject ?? '', {
            id: 'subject',
            class: 'input',
            placeholder: 'Waar gaat je vraag over?'
          }) }}
					{{ submission ? errorList(submission.getErrors('subject')) }}
				</div>

				<div class="field field-full">
					<label class="label" for="message">Jouw vraag</label>
					{{ tag('textarea', {
            id: 'message',
            class: 'textarea',
            name: 'message',
            rows: 5,
            placeholder: 'Wat is iets waarvan jij wou dat iemand het jou had uitgelegd?',
            text: submission.message ?? ''
          }) }}
					{{ submission ? errorList(submission.getErrors('message')) }}
				</div>

				<div class="actions">
					<button class="btn-primary" type="submit">Verzenden</button>
				</div>
			</form>
		</div>
	</section>
{% endblock %}

{% block footer %}
	{% include "_partials/footer.twig" %}
{% endblock %}
